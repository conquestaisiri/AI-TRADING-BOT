# ─────────────────────────────────────────────────────────────────────────────
# Binance Futures Testnet Credentials
#   Get credentials from: https://testnet.binancefuture.com
#   This is the FUTURES testnet, NOT the Spot testnet — they are separate.
#   The Futures testnet supports real long and short via USDT-M contracts.
# ─────────────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=YOUR_FUTURES_TESTNET_API_KEY
BINANCE_API_SECRET=YOUR_FUTURES_TESTNET_API_SECRET
EXCHANGE_TYPE=future

# ─────────────────────────────────────────────────────────────────────────────
# Symbols to trade (comma-separated USDT-M futures pairs)
# ─────────────────────────────────────────────────────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT

# ─────────────────────────────────────────────────────────────────────────────
# Core Risk Parameters
# ─────────────────────────────────────────────────────────────────────────────
# Maximum % of balance risked per trade (e.g. 1.0 = 1%)
RISK_PERCENT=1.0

# Take profit is REWARD_TO_RISK × stop distance (e.g. 2.0 = 2:1 R:R)
REWARD_TO_RISK=2.0

# Stop-loss placed at entry ± (ATR × ATR_STOP_MULTIPLIER)
ATR_STOP_MULTIPLIER=1.5

# Fallback balance if exchange returns 0. Set to your real testnet balance.
STARTING_DEMO_BALANCE_USDT=10000.0

# ─────────────────────────────────────────────────────────────────────────────
# Market Regime Filter
# The bot only trades when the market is classified as "trending".
# Regime score combines 4 rule-based factors (each worth 0.25):
#   1. EMA20/50 spread strength
#   2. EMA20 slope direction and magnitude
#   3. ATR expanding above its own moving average
#   4. Price on the correct side of both EMAs
#
# Score >= REGIME_MIN_TREND_SCORE → "trending" (trade allowed)
# Score  0.30 to < threshold     → "ranging"  (no trade)
# Score < 0.30                   → "choppy"   (no trade)
#
# Increase to be more selective. 0.50 is a moderate filter.
# ─────────────────────────────────────────────────────────────────────────────
REGIME_MIN_TREND_SCORE=0.50

# ─────────────────────────────────────────────────────────────────────────────
# Volume Filter
# Breakout candle volume must be >= this multiple of the 20-bar average
# ─────────────────────────────────────────────────────────────────────────────
VOLUME_RATIO_THRESHOLD=1.5

# ─────────────────────────────────────────────────────────────────────────────
# Overextension Filters
# Prevent entering after the move has already happened.
# ─────────────────────────────────────────────────────────────────────────────
# Reject if breakout candle body > MAX_BODY_ATR_RATIO × ATR
# (catches large candles where you are chasing a big move)
MAX_BODY_ATR_RATIO=2.0

# Reject if price is further than MAX_DISTANCE_FROM_EMA_ATR_RATIO × ATR from EMA20
# (catches overextended entries far from the moving average)
MAX_DISTANCE_FROM_EMA_ATR_RATIO=3.0

# ─────────────────────────────────────────────────────────────────────────────
# Breakout Quality Filters
# ─────────────────────────────────────────────────────────────────────────────
# Close must exceed the breakout level by at least this multiple of ATR.
# Prevents wick-only fake breaks where close barely touched the level.
BREAKOUT_CLOSE_BUFFER_RATIO=0.10

# Candle body must be >= this fraction of the total candle range.
# Rejects wick-heavy candles that signal rejection rather than conviction.
MIN_BODY_TO_RANGE_RATIO=0.40

# ─────────────────────────────────────────────────────────────────────────────
# RSI Extremes Filter
# ─────────────────────────────────────────────────────────────────────────────
RSI_OVERBOUGHT=72.0
RSI_OVERSOLD=28.0

# ─────────────────────────────────────────────────────────────────────────────
# Trend Clarity and ATR Minimum
# ─────────────────────────────────────────────────────────────────────────────
# Minimum EMA20/EMA50 spread as % of price. Below = no directional trend.
EMA_MIN_SPREAD_PCT=0.10

# Minimum ATR as % of price. Below = market is dead/choppy.
ATR_MIN_PCT=0.05

# ─────────────────────────────────────────────────────────────────────────────
# Cooldown After Closed Trades
# After a trade closes, new entries on that symbol are blocked for N 15m candles.
# Cooldown is persistent — counted from the actual close timestamp, not loops.
# ─────────────────────────────────────────────────────────────────────────────
LOSS_COOLDOWN_CANDLES=3
WIN_COOLDOWN_CANDLES=1

# ─────────────────────────────────────────────────────────────────────────────
# Trade Frequency Limiter
# ─────────────────────────────────────────────────────────────────────────────
# Maximum trades per symbol within a rolling TRADE_WINDOW_MINUTES window
MAX_TRADES_PER_WINDOW=3

# Rolling window for frequency counting (minutes)
TRADE_WINDOW_MINUTES=480

# Minimum minutes that must elapse between consecutive entries on the same symbol
MIN_ENTRY_GAP_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
OHLCV_LIMIT=300
LOOP_INTERVAL_SECONDS=900

# ─────────────────────────────────────────────────────────────────────────────
# Backtesting Engine
#
# No API key is required to run the backtest — historical OHLCV data is fetched
# from the public Binance USDT-M endpoint. The settings below control simulation
# assumptions and which files are exported.
# ─────────────────────────────────────────────────────────────────────────────

# Starting balance for the backtest simulation (USDT)
BACKTEST_INITIAL_BALANCE=10000.0

# Trading fee per leg as a decimal.
# 0.0004 = 0.04% — Binance USDT-M futures taker fee.
# Both entry and exit legs are charged, so round-trip cost = 2 × this value.
BACKTEST_FEE_RATE=0.0004

# Slippage per leg as a decimal.
# 0.0002 = 0.02% — conservative estimate for liquid markets.
# Applied adversely on both entry and exit.
BACKTEST_SLIPPAGE_RATE=0.0002

# Entry mode for the simulator.
# Currently only "next_open" is supported:
#   Entry is placed at the open of the candle immediately after signal confirmation.
#   This avoids look-ahead bias — the signal candle's own close is NOT used as entry.
BACKTEST_ENTRY_MODE=next_open

# Total 15m candles to load per symbol.
# The 1h candles are fetched automatically (candles // 4 + buffer).
# Approximate date windows:
#   2000  ≈ 21 days
#   6000  ≈ 63 days
#   10000 ≈ 104 days
BACKTEST_CANDLE_LIMIT=2000

# Symbols to backtest (comma-separated USDT-M futures pairs).
# Leave blank to use the live SYMBOLS setting.
# Example: BACKTEST_SYMBOLS=BTCUSDT,ETHUSDT
BACKTEST_SYMBOLS=

# Directory where backtest output files are written.
# Each symbol gets its own subdirectory: <BACKTEST_EXPORT_DIR>/<SYMBOL>/
# Files exported per symbol:
#   trades.csv        — full trade-by-trade log
#   equity_curve.csv  — balance snapshot after each trade
#   summary.json      — all metrics as JSON
#   report.md         — human-readable markdown report
#   sweep/            — parameter sweep results (if --sweep flag is used)
BACKTEST_EXPORT_DIR=backtest_results
