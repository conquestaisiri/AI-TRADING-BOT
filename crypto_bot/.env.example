# =============================================================
# Binance FUTURES Testnet credentials
# Sign up at: https://testnet.binancefuture.com
# (This is different from the Spot testnet — futures supports both long AND short)
# =============================================================
BINANCE_API_KEY=your_futures_testnet_api_key_here
BINANCE_API_SECRET=your_futures_testnet_api_secret_here

# Exchange type — must be "future" for proper long/short demo trading
EXCHANGE_TYPE=future

# Symbols to trade (comma-separated Binance futures pairs)
SYMBOLS=BTCUSDT,ETHUSDT

# Risk per trade as percentage of account balance (e.g. 1.0 = 1%)
RISK_PERCENT=1.0

# Take profit as multiple of stop distance (e.g. 2.0 = 2:1 reward/risk)
REWARD_TO_RISK=2.0

# ATR stop multiplier — stop is placed at entry ± (ATR * this)
ATR_STOP_MULTIPLIER=1.5

# Fallback balance if API returns zero (used for sizing in demo mode)
STARTING_DEMO_BALANCE_USDT=10000.0

# Strategy filters
RSI_OVERBOUGHT=72.0      # Don't enter long above this RSI
RSI_OVERSOLD=28.0        # Don't enter short below this RSI
EMA_MIN_SPREAD_PCT=0.1   # Minimum EMA20/EMA50 spread % to confirm real trend
ATR_MIN_PCT=0.05         # Minimum ATR as % of price (below = choppy, skip)

# Loss cooldown: pause trading after N consecutive losses for M loops
LOSS_COOLDOWN_COUNT=2
LOSS_COOLDOWN_LOOPS=2

# How many candles to fetch per request
OHLCV_LIMIT=300

# Loop interval in seconds (900 = 15 minutes, matches 15m strategy timeframe)
LOOP_INTERVAL_SECONDS=900
